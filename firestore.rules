rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /accidents/{reportId} {
      function reporterIdentityUnchanged() {
        return request.resource.data.reporterId == resource.data.reporterId
          && request.resource.data.dispatchId == resource.data.dispatchId
          && request.resource.data.reporterEmail == resource.data.reporterEmail;
      }

      function ownerCanUpdateAccident() {
        return resource.data.reporterId == request.auth.uid
          && reporterIdentityUnchanged()
          && (
            (resource.data.status == 'ACTIVE' && request.resource.data.status in ['ACTIVE', 'RESOLUTION_PENDING'])
            || (resource.data.status == 'RESOLUTION_PENDING' && request.resource.data.status in ['RESOLUTION_PENDING', 'ACTIVE'])
            || (resource.data.status == 'RESOLVED' && request.resource.data.status in ['RESOLVED', 'ACTIVE'])
          )
          && (
            request.resource.data.status != 'RESOLUTION_PENDING'
            || (
              request.resource.data.resolution is map
              && request.resource.data.resolution.note is string
              && request.resource.data.resolution.note.size() >= 12
              && request.resource.data.resolution.confirmedBy is list
              && request.auth.uid in request.resource.data.resolution.confirmedBy
            )
          );
      }

      function canConfirmResolutionAsSecondDispatcher() {
        return resource.data.status == 'RESOLUTION_PENDING'
          && request.resource.data.status in ['RESOLUTION_PENDING', 'RESOLVED']
          && request.auth.uid != resource.data.reporterId
          && reporterIdentityUnchanged()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolution', 'updatedAt'])
          && resource.data.resolution is map
          && request.resource.data.resolution is map
          && resource.data.resolution.confirmedBy is list
          && request.resource.data.resolution.confirmedBy is list
          && request.resource.data.resolution.confirmedBy.hasAll(resource.data.resolution.confirmedBy)
          && request.auth.uid in request.resource.data.resolution.confirmedBy
          && !(request.auth.uid in resource.data.resolution.confirmedBy)
          && request.resource.data.resolution.confirmedBy.size() == resource.data.resolution.confirmedBy.size() + 1
          && (request.resource.data.status != 'RESOLVED' || request.resource.data.resolution.confirmedBy.size() >= 2);
      }

      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reporterEmail == request.auth.token.email
        && request.resource.data.dispatchId is string
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.severity in ['LOW', 'MEDIUM', 'HIGH', 'CRITICAL']
        && request.resource.data.status == 'ACTIVE'
        && request.resource.data.responseCount is int;

      allow update: if isSignedIn()
        && (ownerCanUpdateAccident() || canConfirmResolutionAsSecondDispatcher());

      allow delete: if isSignedIn() && resource.data.reporterId == request.auth.uid;
    }
  }
}
